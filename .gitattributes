# Normalize line endings to LF on checkout and commit.
* text=auto eol=lf

# Explicitly declare text files
*.js    text
*.jsx   text
*.json  text
*.css   text
*.html  text
*.md    text
*.yml   text
*.yaml  text
*.svg   text

# Denote binary files that should not be modified
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary

# GitHub Linguist hints
package-lock.json linguist-generated=true
*.md              linguist-documentation
