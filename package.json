{
  "name": "rot47-converter",
  "version": "1.1.0",
  "type": "module",
  "description": "A fast, privacy-friendly web tool to encode and decode text with the ROT47 cipher. Built with React + Vite and available in 25 languages.",
  "keywords": [
    "rot47",
    "cipher",
    "encoder",
    "decoder",
    "cryptography",
    "text-obfuscation",
    "react",
    "vite",
    "i18n"
  ],
  "author": "justyy (DoctorLai) (https://justyy.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DoctorLai/rot47-converter.git"
  },
  "bugs": {
    "url": "https://github.com/DoctorLai/rot47-converter/issues"
  },
  "homepage": "https://doctorlai.github.io/rot47-converter",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest --watch=false",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"*.{js,json,md,yml,yaml}\" \".github/**/*.{md,yml,yaml,json}\" \"src/**/*.{js,jsx,json,css}\" \"tests/**/*.{js,jsx}\"",
    "format:fix": "prettier --write \"*.{js,json,md,yml,yaml}\" \".github/**/*.{md,yml,yaml,json}\" \"src/**/*.{js,jsx,json,css}\" \"tests/**/*.{js,jsx}\"",
    "check": "npm run format && npm run lint && npm run coverage && npm run build",
    "add-version": "echo \"VITE_COMMIT_HASH=$(git rev-parse --short HEAD)\" > .env && echo \"VITE_APP_VERSION=$(date -u +%Y-%m-%d)\" >> .env",
    "deploy": "npm run add-version && npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
